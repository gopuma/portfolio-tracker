# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=portfoliopass
DB_ROOT_PASSWORD=rootpass

# Backend
PORT=4000
NODE_ENV=development

# Cron schedule (every weekday at 23:00 KST)
CRON_DAILY_REFRESH=0 23 * * 1-5

# Frontend (Vite reads VITE_* vars)
VITE_API_BASE=http://localhost:4000/api
