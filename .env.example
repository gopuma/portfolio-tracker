# Copy this file to .env at the PROJECT ROOT and fill in real values:
#     cp .env.example .env
# .env is gitignored and must NEVER be committed. The backend loads this root
# .env via backend/src/env.js; docker-compose reads it automatically.
#
# Generate strong passwords, e.g.:  openssl rand -hex 24

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
DB_ROOT_PASSWORD=REPLACE_WITH_A_STRONG_ROOT_PASSWORD

# Backend
PORT=4000
NODE_ENV=development

# Cron schedule (every weekday at 23:00 KST)
CRON_DAILY_REFRESH=0 23 * * 1-5

# ML sidecar (Phase 2 — gradient-boosting models). ML_SIDECAR_PORT is the host port
# docker-compose maps to the container's 8000; the backend reaches it via ML_SIDECAR_URL.
# If the sidecar is down, the backend simply skips the boosting models.
ML_SIDECAR_PORT=8008
ML_SIDECAR_URL=http://localhost:8008

# Frontend (Vite reads VITE_* vars). Only needed for non-dev; dev proxies /api automatically.
VITE_API_BASE=http://localhost:4000/api
